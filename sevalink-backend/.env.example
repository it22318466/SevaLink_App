# Database Configurations
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sevalink_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# JWT Configuration (At least 64 characters for HS512)
JWT_SECRET=your_jwt_secret_must_be_at_least_64_characters_long

# Email Configurations (Gmail SMTP)
SPRING_MAIL_USERNAME=your_gmail_address@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password_here

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Push Notification (FCM) Configuration
FIREBASE_CONFIG_PATH=classpath:firebase-service-account.json
